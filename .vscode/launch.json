{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI Debug statement_parser_service",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "services.statement_parser_service.main:app",
                "--reload",
                "--port", "8001"
            ],
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "FastAPI Debug embedding_service",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "services.embedding_service.main:app",
                "--reload",
                "--port", "8002"
            ],
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}